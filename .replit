language = "python3"
run = "python app.py"
modules = ["python-3.11"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CANTEEN_WEBSITE"

[[workflows.workflow]]
name = "CANTEEN_WEBSITE"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 1; python app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
